{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "include": ["apps/*/src/**/*.{ts,tsx}", "packages/*/src/**/*.{ts,tsx}"],
  "exclude": [
    "**/*.test.{ts,tsx}",
    "**/*.stories.{ts,tsx}",
    "**/assets/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/*.config.{js,ts}",
    "**/rspack/**"
  ],
  "reporter": ["text", "text-summary", "html", "lcov", "json"],
  "report-dir": "./coverage",
  "temp-dir": "./coverage/.nyc_output",
  "check-coverage": true,
  "lines": 80,
  "statements": 80,
  "functions": 80,
  "branches": 80,
  "cache": false,
  "instrument": true,
  "source-map": true
}
